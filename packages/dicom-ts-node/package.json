    "index.cjs",
    "index.d.ts",
    "dist"
  ],
  "license": "MIT",
  "dependencies": {
    "dicom-ts": "0.2.0-alpha.0"
  },
  "optionalDependencies": {
    "sharp": "^0.34.0"
  }
}
