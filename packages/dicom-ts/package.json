{
  "name": "dicom-ts",
  "version": "0.2.0-alpha.0",
  "description": "Browser-safe DICOM toolkit for TypeScript",
  "type": "module",
  "main": "./index.cjs",
  "module": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "import": "./index.js",
      "require": "./index.cjs",
      "types": "./index.d.ts"
    }
  },
  "files": [
    "index.js",
    "index.cjs",
    "index.d.ts",
    "dist"
  ],
  "license": "MIT",
  "dependencies": {
    "iconv-lite": "^0.7.2",
    "jpeg-js": "^0.4.4",
    "upng-js": "^2.1.0"
  }
}
