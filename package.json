{
  "name": "dicom-ts-workspace",
  "version": "0.2.0-alpha.0",
  "private": true,
  "description": "dicom-ts workspace",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build": "npm run build:cjs && npm run build:esm && npm run build:packages",
    "build:packages": "node scripts/sync-package-dist.mjs",
    "build:all": "npm run build && npm run check:browser-safe",
    "check:browser-safe": "node scripts/check-browser-safe.mjs",
    "test": "vitest run --maxWorkers=1",
    "test:watch": "vitest --maxWorkers=1",
    "test:coverage": "vitest run --coverage --maxWorkers=1",
    "bench": "vitest bench",
    "generate:dict": "node scripts/generate-dict.mjs",
    "tool:dicom-to-json": "node tools/dicom-to-json/index.mjs",
    "tool:dicom-to-json:help": "node tools/dicom-to-json/index.mjs --help",
    "tool:dicom-info": "node tools/dicom-info/index.mjs",
    "tool:dicom-info:help": "node tools/dicom-info/index.mjs --help",
    "tool:dicom-dump": "node tools/dicom-dump/index.mjs",
    "tool:dicom-dump:help": "node tools/dicom-dump/index.mjs --help",
    "tool:dicom-cstore-scu": "node tools/dicom-cstore-scu/index.mjs",
    "tool:dicom-cstore-scu:help": "node tools/dicom-cstore-scu/index.mjs --help",
    "tool:dicom-cstore-scp": "node tools/dicom-cstore-scp/index.mjs",
    "tool:dicom-cstore-scp:help": "node tools/dicom-cstore-scp/index.mjs --help",
    "tool:dicom-qr-scu": "node tools/dicom-qr-scu/index.mjs",
    "tool:dicom-qr-scu:help": "node tools/dicom-qr-scu/index.mjs --help",
    "tool:dicom-qr-scp": "node tools/dicom-qr-scp/index.mjs",
    "tool:dicom-qr-scp:help": "node tools/dicom-qr-scp/index.mjs --help",
    "tool:dicom-worklist-scu": "node tools/dicom-worklist-scu/index.mjs",
    "tool:dicom-worklist-scu:help": "node tools/dicom-worklist-scu/index.mjs --help",
    "tool:dicom-worklist-scp": "node tools/dicom-worklist-scp/index.mjs",
    "tool:dicom-worklist-scp:help": "node tools/dicom-worklist-scp/index.mjs --help",
    "tool:dicom-transcode": "node tools/dicom-transcode/index.mjs",
    "tool:dicom-transcode:help": "node tools/dicom-transcode/index.mjs --help",
    "tool:dicom-to-jpeg": "node tools/dicom-to-jpeg/index.mjs",
    "tool:dicom-to-jpeg:help": "node tools/dicom-to-jpeg/index.mjs --help"
  },
  "keywords": [
    "dicom",
    "medical-imaging",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.19.11",
    "@types/jpeg-js": "^0.3.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
